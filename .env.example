# Feluda environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# Secrets are loaded only by the API server; they must never reach the frontend,
# prompts, or logs (see CLAUDE.md — Privacy by default, SPEC.md — Secrets Vault).

# ─── Runtime ───────────────────────────────────────────────────────────────
NODE_ENV=development
# Port the Fastify API server listens on.
API_PORT=3001
# Origin the web app is served from (used for CORS).
WEB_ORIGIN=http://localhost:5173

# ─── AI providers (Layer III — Model Gateway) ────────────────────────────────
# Phase 1: Anthropic is the default provider.
ANTHROPIC_API_KEY=
# Default model id used by the gateway.
FELUDA_DEFAULT_MODEL=claude-opus-4-8
# Additional providers slot in behind the gateway in Phase 4 (leave blank now).
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ─── Evidence & Sources (Layer IV) — added in Phase 2 ────────────────────────
# Web/news search provider key (e.g. Tavily / Brave / Bing). Leave blank now.
WEB_SEARCH_API_KEY=

# ─── OSINT (Layer IV) ────────────────────────────────────────────────────────
# Enable keyless live OSINT providers (RDAP + DNS-over-HTTPS). Passive only.
FELUDA_OSINT_LIVE=false
# Optional key for the key-gated reputation / threat-intel provider.
FELUDA_REPUTATION_API_KEY=

# ─── Memory (Layer V) — added in Phase 3 ─────────────────────────────────────
# Path to the local, swappable vector store.
VECTOR_STORE_PATH=./data/vector-store
# Remote SEMANTIC embeddings (true RAG). When set, the Knowledge Vault uses a
# real embedding API instead of the offline lexical embedder.
FELUDA_EMBEDDING_API_KEY=
FELUDA_EMBEDDING_MODEL=text-embedding-3-small
FELUDA_EMBEDDING_BASE_URL=

# ─── Council cost control (Layer III) — added in Phase 4 ─────────────────────
# Hard cap (USD) per investigation before falling back to a single model.
COUNCIL_COST_CAP_USD=0.50

# ─── API hardening ───────────────────────────────────────────────────────────
# When set, every /api/* request must send this key (x-api-key or Bearer).
FELUDA_API_KEY=
# Max request body size (bytes) and per-IP requests/minute.
FELUDA_MAX_BODY_BYTES=1000000
FELUDA_RATE_LIMIT_MAX=240
# Persist investigation cases / adaptive learning to JSON files (survive restart).
FELUDA_CASES_PATH=./data/cases.json
FELUDA_FEEDBACK_PATH=./data/feedback.json
FELUDA_PLAYBOOKS_PATH=./data/playbooks.json

# ─── Live model integration test (opt-in; CI/dev only) ───────────────────────
# When set, packages/core live-model.test.ts runs a real investigation.
FELUDA_TEST_API_KEY=
FELUDA_TEST_PROVIDER=anthropic
FELUDA_TEST_MODEL=
FELUDA_TEST_BASE_URL=

# ─── Frontend (Vite) ─────────────────────────────────────────────────────────
# Vite only exposes vars prefixed with VITE_. Base URL of the API.
VITE_API_BASE_URL=http://localhost:3001

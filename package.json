{
  "name": "feluda",
  "version": "0.0.0",
  "private": true,
  "description": "Feluda — a calm, rigorous investigative reasoning assistant.",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "packages/core",
    "packages/api",
    "packages/web",
    "packages/cli"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm run dev --workspace @feluda/api",
    "dev:web": "npm run dev --workspace @feluda/web",
    "feluda": "tsx packages/cli/src/index.ts",
    "build": "npm run build --workspace @feluda/core && npm run build --workspace @feluda/api && npm run build --workspace @feluda/web && npm run build --workspace @feluda/cli",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.3.2",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
